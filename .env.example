# ──────────────────────────────────────────────────────────────────────────
# Anfaia Jobs AI — environment variables
# Copy this file to `.env` and fill in the values.
# ──────────────────────────────────────────────────────────────────────────

# --- Application --------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# --- Database -----------------------------------------------------------------
# Single source of truth for the PostgreSQL connection. The app builds
# DATABASE_URL from these parts when DATABASE_URL is not set.
# docker-compose also uses them to initialize the `postgres` container.
POSTGRES_USER=anfaia
POSTGRES_PASSWORD=anfaia
POSTGRES_DB=anfaia_jobs
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Full async DSN (optional). If set, it TAKES PRECEDENCE over the POSTGRES_*
# variables above. Leave it empty to let it be assembled automatically.
# Note: in docker-compose the host must be `postgres` (compose sets it).
# DATABASE_URL=postgresql+asyncpg://anfaia:anfaia@localhost:5433/anfaia_jobs

# --- LLM providers ------------------------------------------------------------
# Select the active provider: openai | anthropic | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Embeddings ---------------------------------------------------------------
# Embedding provider: openai | hash (hash = deterministic local fallback)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Cosine similarity threshold to consider two job offers duplicates (0-1)
DUPLICATE_SIMILARITY_THRESHOLD=0.90

# --- Discord ------------------------------------------------------------------
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# --- Scheduler ----------------------------------------------------------------
SCHEDULER_ENABLED=true
POST_TIME=10:00
TIMEZONE=Europe/Madrid

# --- Collection ---------------------------------------------------------------
# Max number of offers fetched per source
MAX_ITEMS_PER_SOURCE=25
# Minimum relevance score (0-100) for an offer to be a candidate
MIN_RELEVANCE_SCORE=55
# Max number of offers published per run
MAX_OFFERS_PER_RUN=3
# Keyword pre-filter (comma-separated, case-insensitive). An offer must match at
# least one keyword in its title/tags/description to enter the pipeline. Empty
# disables the filter (everything goes to the LLM classifier).
JOB_KEYWORDS=ai,machine learning,ml,llm,data,python,deep learning,nlp,mlops
# User-Agent used on outbound HTTP requests
HTTP_USER_AGENT=AnfaiaJobsAI/0.1 (+https://anfaia.org)
HTTP_TIMEOUT_SECONDS=20

# --- Sources ------------------------------------------------------------------
# Remotive (https://remotive.com) — free JSON API of remote jobs.
REMOTIVE_ENABLED=true
REMOTIVE_CATEGORY=software-dev
# RemoteOK (https://remoteok.com) — free JSON API.
REMOTEOK_ENABLED=true
# Arbeitnow (https://www.arbeitnow.com) — free JSON API (mostly EU jobs).
ARBEITNOW_ENABLED=true
# Extra RSS/Atom job feeds: "Name|URL" entries separated by commas (or newlines).
# Leave empty to use the built-in catalog (see app/infrastructure/sources/registry.py):
# SEPE Informática/Telecomunicaciones, We Work Remotely (Programming + DevOps),
# Himalayas and Real Work From Anywhere. Setting this variable REPLACES the
# catalog, so include the defaults you want to keep.
# Tip España/IT: Tecnoempleo genera un RSS por búsqueda (haz tu búsqueda en
# https://www.tecnoempleo.com/ofertas-trabajo/ y copia el enlace RSS resultante),
# y https://www.empleorss.com/ genera feeds de Tecnoempleo por provincia.
# Example: JOB_RSS_FEEDS=Tecnoempleo IA|https://www.tecnoempleo.com/rss/...,Otro|https://otro.com/feed
JOB_RSS_FEEDS=
